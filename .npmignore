# The in-place build (tsconfig.build.json) compiles src/*.ts → src/*.js and
# srv/*.ts → srv/*.js. We ship the compiled .js + .d.ts; strip the .ts source
# and dev-only artifacts from the published tarball.

# TypeScript sources (keep .d.ts declarations, drop everything else)
src/**/*.ts
!src/**/*.d.ts
srv/**/*.ts
!srv/**/*.d.ts

# Source maps + buildinfo
**/*.ts.map
**/*.d.ts.map
**/*.js.map
*.tsbuildinfo

# Test files
test/
**/*.test.ts
**/*.spec.ts

# Configs not needed by consumers
tsconfig.json
tsconfig.build.json
jest.config.js
eslint.config.mjs
.eslintrc*
.prettierrc*
.editorconfig
.env
.env.*

# Dev-only directories
docs/
.github/
.gitlab-ci.yml
.travis.yml
coverage/
gen/
dist/
example/
demo/
scripts/
tmp/
temp/

# IDE / OS noise
.vscode/
.claude/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Repo-private files
.git/
.gitignore
.gitattributes
*.log
*.db
*.sqlite
IMPROVEMENTS.md
